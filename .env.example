# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
POSTGRES_DB=kitchen_db
POSTGRES_USER=kitchen_user
POSTGRES_PASSWORD=kitchen_pass

# ─────────────────────────────────────────────
# Security — CHANGE BEFORE PRODUCTION
# ─────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# Ollama — local LLM (optional)
# Install ollama, run: ollama pull llama3.2
# ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─────────────────────────────────────────────
# Email (SMTP) — for expiry notifications
# For Gmail: enable 2FA, create an App Password
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
NOTIFICATIONS_ENABLED=true

# ─────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─────────────────────────────────────────────
# OCR
# ─────────────────────────────────────────────
OCR_ENGINE=paddle   # paddle | tesseract

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
APP_ENV=development  # development | production
DEBUG=true
